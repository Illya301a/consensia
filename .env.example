# Переменные использует src/services/
# OAuth front_url для «Увійти» формується з window.location.origin + /app (див. AuthContext.loginWithGoogle).

# Бэкенд (consensia-api.faby.world)
VITE_API_BASE_URL=https://consensia-api.faby.world

# Оркестратор WebSocket; локально: ws://localhost:8050/ws/orchestrator
VITE_ORCHESTRATOR_WS_URL=wss://consensia-api.faby.world/ws/orchestrator
